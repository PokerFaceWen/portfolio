---
import BaseLayout from '../layouts/BaseLayout.astro';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const photoModules = import.meta.glob(
  '/public/photos/**/*.{jpg,jpeg,png,webp,JPG,PNG}',
  { eager: true, query: '?url', import: 'default' }
);

const photos = Object.entries(photoModules)
  .map(([path, url]) => {
    const filename = path.split('/').pop() || '';
    const name = filename.replace(/\.\w+$/, '');
    return { src: `${base}photos/${filename}`, name };
  })
  .sort((a, b) => b.name.localeCompare(a.name));
---

<BaseLayout title="Photos | PokerFaceWen" description="My photo collection and wallpaper gallery.">
  <div class="max-w-6xl mx-auto animate-slide-enter">
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-3xl font-bold font-condensed">Photos</h1>
      <p class="text-sm opacity-40 italic">A personal collection of photos and wallpapers.</p>
    </div>

    {photos.length === 0 ? (
      <div class="prose-custom">
        <p class="opacity-50">No photos yet. Add your images to <code class="font-mono text-sm bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded">public/photos/</code> directory.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3">
        {photos.map((photo) => (
          <div class="group relative overflow-hidden rounded-lg bg-gray-100 dark:bg-gray-900 aspect-square">
            <img
              src={photo.src}
              alt={photo.name}
              loading="lazy"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300" />
          </div>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
